# Club Portal environment template
# Copy the values you need into your shell, CI secrets, or the host env file.
# The frontend does not auto-read this file. It is a reviewer/deployment template.

# Runtime profile
SPRING_PROFILES_ACTIVE=dev

# Core app
JWT_SECRET=replace-with-at-least-32-characters
APP_PUBLIC_BASE_URL=http://localhost:5173
APP_SECURITY_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:5173,http://127.0.0.1:5173
APP_PUBLIC_PRIVACY_CONTACT_EMAIL=
APP_PUBLIC_DATA_CONTROLLER_NAME=Club Booking Portal
APP_PUBLIC_RETENTION_SUMMARY=Chat, booking, membership, and payment records are currently retained until manually deleted or a formal retention schedule is applied.
APP_PUBLIC_PROCESSORS_SUMMARY=Google sign-in, Google Maps, Stripe, and AI chat providers may be used depending on deployment configuration.
APP_SECURITY_AUDIT_ENABLED=true
APP_SECURITY_ALERTS_ENABLED=true
APP_SECURITY_ALERT_EMAIL_TO=
APP_SECURITY_SESSION_AUTH_TOKEN_TTL_DAYS=7
APP_SECURITY_SESSION_STREAM_TOKEN_TTL_DAYS=1

# Database
# Leave these blank for local dev if you use the backend dev profile with H2.
SPRING_DATASOURCE_URL=
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=
DB_URL=
DB_USERNAME=
DB_PASSWORD=

# One-off production club bootstrap
# Leave disabled unless you intentionally want to replace the current club dataset online.
APP_SEED_PRODUCTION_CLUBS_ENABLED=false
APP_SEED_PRODUCTION_CLUBS_EXPECTED_EXISTING_CLUB_COUNT=2
APP_SEED_PRODUCTION_CLUBS_EXPECTED_EXISTING_CLUB_USER_COUNT=2
APP_SEED_PRODUCTION_CLUBS_ALLOW_EMPTY_DATASET=false
APP_SEED_PRODUCTION_COMMUNITY_QA_ENABLED=false
APP_SEED_PRODUCTION_CLUB_CONTENT_REFRESH_ENABLED=false

# Mail
SPRING_MAIL_HOST=
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
APP_MAIL_FROM=no-reply@example.test
MAIL_FROM=no-reply@example.test

# OAuth, maps, and LLM
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_MAPS_JS_API_KEY=
OPENAI_API_KEY=
APP_LLM_API_KEY=
APP_LLM_API_BASE_URL=https://api.openai.com
APP_LLM_MODEL=gpt-5-mini
APP_LLM_EMBEDDING_MODEL=text-embedding-3-small

# Payments
APP_PAYMENTS_MODE=VIRTUAL
APP_PAYMENTS_CURRENCY=GBP
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
